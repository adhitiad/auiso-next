generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                  String             @id @default(cuid())
  username            String             @unique
  email               String             @unique
  role                String             @default("user")
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt
  name                String?
  image               String?
  password            String?
  usernameChanged     Boolean            @default(false)
  passwordChangeCount Int                @default(0)
  emailVerified       DateTime?
  accounts            Account[]
  sessions            Session[]
  bookmarks           Bookmark[]
  comments            Comment[]
  Like                Like[]
  PushSubscription    PushSubscription[]
  watchHistory        WatchHistory[]
}

model Video {
  id                  String                @id @default(cuid())
  title               String
  slug                String                @unique
  synopsis            String
  thumbnail           String
  duration            Int?
  isFeatured          Boolean               @default(false)
  peerTubeId          String?
  externalSourceUrl   String?
  videoPlatform       String?
  videoId             String?
  isLive              Boolean               @default(false)
  releaseDate         DateTime
  views               Int                   @default(0)
  moderationStatus    String                @default("SAFE")
  moderationScore     Float?
  createdAt           DateTime              @default(now())
  updatedAt           DateTime              @updatedAt
  videoSources        Json?
  summary             String?
  isTelegramNotified  Boolean               @default(false)
  bookmarks           Bookmark[]
  CategoryOnVideo     CategoryOnVideo[]
  comments            Comment[]
  Like                Like[]
  TagOnVideo          TagOnVideo[]
  UserEvent           UserEvent[]
  VideoRecommendation VideoRecommendation[]
  watchHistory        WatchHistory[]
}

model Category {
  id              String            @id @default(cuid())
  name            String            @unique
  slug            String            @unique
  type            String
  description     String?
  createdAt       DateTime          @default(now())
  CategoryOnVideo CategoryOnVideo[]
}

model Tag {
  id         String       @id @default(cuid())
  name       String       @unique
  createdAt  DateTime     @default(now())
  TagOnVideo TagOnVideo[]
}

model Comment {
  id        String   @id @default(cuid())
  content   String
  userId    String
  videoId   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  video     Video    @relation(fields: [videoId], references: [id], onDelete: Cascade)
}

model WatchHistory {
  id        String   @id @default(cuid())
  userId    String
  videoId   String
  watchedAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  video     Video    @relation(fields: [videoId], references: [id], onDelete: Cascade)

  @@unique([userId, videoId])
}

model Bookmark {
  id        String   @id @default(cuid())
  userId    String
  videoId   String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  video     Video    @relation(fields: [videoId], references: [id], onDelete: Cascade)

  @@unique([userId, videoId])
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model AdPurchase {
  id             String   @id
  slotId         String
  advertiserName String
  bannerUrl      String
  targetUrl      String
  startDate      DateTime
  endDate        DateTime
  impressions    Int      @default(0)
  clicks         Int      @default(0)
  active         Boolean  @default(true)
  status         String   @default("PENDING")
  createdAt      DateTime @default(now())
  updatedAt      DateTime
  AdSlot         AdSlot   @relation(fields: [slotId], references: [id], onDelete: Cascade)
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model AdSlot {
  id         String       @id
  name       String
  position   String
  price      Float
  active     Boolean      @default(true)
  createdAt  DateTime     @default(now())
  updatedAt  DateTime
  AdPurchase AdPurchase[]
}

model BlockStatus {
  id        String   @id
  country   String   @unique
  status    String
  checkedAt DateTime @default(now())
}

model CategoryOnVideo {
  id         String   @id
  videoId    String
  categoryId String
  createdAt  DateTime @default(now())
  Category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  Video      Video    @relation(fields: [videoId], references: [id], onDelete: Cascade)

  @@unique([videoId, categoryId])
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model Like {
  id        String   @id
  userId    String
  videoId   String
  createdAt DateTime @default(now())
  User      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  Video     Video    @relation(fields: [videoId], references: [id], onDelete: Cascade)

  @@unique([userId, videoId])
}

model PushSubscription {
  id        String   @id
  userId    String
  endpoint  String
  p256dh    String
  auth      String
  createdAt DateTime @default(now())
  User      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, endpoint])
}

model Report {
  id        String   @id
  type      String
  targetId  String
  reason    String
  status    String   @default("PENDING")
  createdAt DateTime @default(now())
  updatedAt DateTime
}

model SearchReferrer {
  id             String   @id
  fingerprint    String
  referrerUrl    String
  searchEngine   String?
  searchKeywords String?
  createdAt      DateTime @default(now())

  @@index([fingerprint])
}

model SharedLink {
  id        String   @id
  url       String
  title     String?
  text      String?
  createdAt DateTime @default(now())
}

model SystemSetting {
  id        String   @id
  key       String   @unique
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime
}

model TagOnVideo {
  id        String   @id
  videoId   String
  tagId     String
  createdAt DateTime @default(now())
  Tag       Tag      @relation(fields: [tagId], references: [id], onDelete: Cascade)
  Video     Video    @relation(fields: [videoId], references: [id], onDelete: Cascade)

  @@unique([videoId, tagId])
}

model UserEvent {
  id          String   @id
  fingerprint String
  videoId     String
  action      String
  createdAt   DateTime @default(now())
  Video       Video    @relation(fields: [videoId], references: [id], onDelete: Cascade)

  @@index([fingerprint])
  @@index([videoId])
}

model VideoRecommendation {
  id          String   @id
  fingerprint String
  videoId     String
  score       Float
  createdAt   DateTime @default(now())
  Video       Video    @relation(fields: [videoId], references: [id], onDelete: Cascade)

  @@unique([fingerprint, videoId])
  @@index([fingerprint])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}
